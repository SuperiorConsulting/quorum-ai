# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/quorum

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (SMS) ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── SendGrid (email) ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Quorum AI

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
STRIPE_STARTER_SETUP_PRICE_ID=price_...
STRIPE_GROWTH_SETUP_PRICE_ID=price_...
STRIPE_ENTERPRISE_SETUP_PRICE_ID=price_...

# ── Vapi AI (voice) ────────────────────────────────────────────────────────────
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...
VAPI_ASSISTANT_ID=...

# ── ElevenLabs (voice cloning) ─────────────────────────────────────────────────
ELEVENLABS_API_KEY=...

# ── Pinecone (vector memory) ───────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX=quorum-memory

# ── Mem0 (structured memory) ───────────────────────────────────────────────────
MEM0_API_KEY=...

# ── GoHighLevel ────────────────────────────────────────────────────────────────
GHL_API_KEY=...
GHL_LOCATION_ID=...
GHL_PIPELINE_ID=...

# ── Google Calendar ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback/google

# ── n8n ────────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://your-n8n.railway.app
N8N_WEBHOOK_SECRET=...

# ── App URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ── Worker feature flags ────────────────────────────────────────────────────────
QUORUM_BRIEFING_CALLS=false   # Set true to trigger Vapi voice briefings

# ── Seed (optional overrides) ─────────────────────────────────────────────────
SEED_EMAIL=demo@yourdomain.com
SEED_PASSWORD=change-me-before-deploy
